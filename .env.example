DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
NEON_ENDPOINT=your-neon-endpoint-id
# Put your key in ONE of these (see README — run scripts/verify_gemini_connection.py to pick GEMINI_CLIENT)
VERTEX_AI_API_KEY=
# GEMINI_API_KEY=
# vertex_express (default) or google_ai_studio
GEMINI_CLIENT=vertex_express
GEMINI_MODEL=gemini-2.5-flash
